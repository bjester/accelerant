{
  "name": "accelerant",
  "version": "0.1.1",
  "description": "A service worker for simplifying your frontend integration with Firebase",
  "homepage": "https://github.com/bjester/accelerant",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjester/accelerant.git"
  },
  "bugs": {
    "url": "https://github.com/bjester/accelerant/issues"
  },
  "main": "src/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --write src/ test/",
    "format": "biome format --write src/ test/",
    "test": "pnpm test:unit && pnpm test:integ",
    "test:unit": "mocha --require test/unit/setup.js \"test/unit/*.test.js\"",
    "test:integ:exec": "mocha --require test/integration/setup.js \"test/integration/**/*.test.js\"",
    "test:integ": "firebase emulators:exec --project demo-accelerant \"pnpm test:integ:exec\"",
    "test:e2e:exec": "playwright test -c test/e2e/playwright.config.js",
    "test:e2e": "firebase emulators:exec --project demo-accelerant \"pnpm test:e2e:exec\""
  },
  "keywords": [
    "firebase",
    "service worker",
    "utility",
    "background",
    "async",
    "cache"
  ],
  "author": "Blaine Jester",
  "funding": {
    "type": "patreon",
    "url": "https://patreon.com/BlaineJester"
  },
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.0.0-dev.1005+sha512.91f84a392eea348ea4852a182912d2520273a4336f933b78cc44bc931eb999923c097e9433a9b355adc1f725725ea99082fc9f032a559df832632e764c92c798",
  "dependencies": {
    "events": "^3.3.0",
    "uuid": "^13.0.0",
    "workbox-expiration": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@playwright/test": "^1.58.2",
    "chai": "^6.2.2",
    "fast-glob": "^3.3.3",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.11.0",
    "mocha": "^11.7.5",
    "rollup": "^4.59.1",
    "rollup-plugin-copy": "^3.5.0",
    "vite": "^8.0.1"
  },
  "peerDependencies": {
    "firebase": "^12.9.0"
  }
}
